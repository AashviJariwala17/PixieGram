@model IEnumerable<Instagram.Models.UserSuggestion>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Suggestions</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
        background-color: #fafafa;
        font-family: Arial, sans-serif;
        }

        .suggestion-card {
        display: flex;
        align-items: center;
        padding: 12px;
        border-bottom: 1px solid #eee;
        }

        .profile-pic {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        margin-right: 15px;
        }

        .username {
        font-weight: 600;
        font-size: 14px;
        }

        .fullname {
        font-size: 13px;
        color: #888;
        }

        .follow-btn {
        margin-left: auto;
        background-color: #3867d6;
        color: #fff;
        border: none;
        padding: 6px 16px;
        border-radius: 6px;
        font-size: 14px;
        }

        .next-btn {
        display: block;
        width: 100%;
        margin-top: 20px;
        background-color: #3867d6;
        color: #fff;
        border: none;
        padding: 10px;
        border-radius: 6px;
        font-size: 16px;
        text-align: center;
        }

        .next-btn:hover {
        background-color: #274b9f;
        }
        .following-btn {
        margin-left: auto;
        background-color: #e4e6eb; /* light gray background */
        color: #000; /* black text */
        border: none;
        padding: 6px 16px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        }

        .following-btn:hover {
        background-color: #d8dadf; /* darker gray on hover */
        }
    </style>
</head>
<body>
    <div class="container mt-4">
        <h5>Suggested for you</h5>
        <div class="list-group mt-3">
            @foreach (var user in Model)
            {
                @foreach (var item in user.data)
                {
                    <div class="suggestion-card">
                        <img src="@(string.IsNullOrEmpty(item.profile) ? Url.Content("~/images/defaultProfilePic.jpg") : item.profile)" class="profile-pic" alt="Profile" />
                        <div>
                            <div class="username">@item.username</div>
                            <div class="fullname">@item.fullName</div>
                        </div>
                        @if (ViewBag.followerId != null && ViewBag.followerId.Contains(item.id))
                        {
                            <a href="#" class="following-btn" style="text-decoration:none">Following</a>
                        }
                        else
                        {
                            <a href="@Url.Action("SendRequest","Authentication", new { id = item.id })" style="text-decoration:none" class="follow-btn">Follow</a>
                        }
                    </div>
                }
            }
        </div>
        <!-- Next Button -->
        @if (ViewBag.followerCnt != null && ViewBag.followerCnt >= 3)
        {
            <a href="@Url.Action("Dashboard","Post")" style="text-decoration:none" class="next-btn">Next</a>
        }
    </div>
</body>
</html>